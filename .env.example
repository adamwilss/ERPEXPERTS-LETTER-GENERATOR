# Vercel/Neon Postgres (auto-configured by Vercel when you add the integration)
# Get these from Vercel Dashboard → Storage → Neon → .env.local
DATABASE_URL=
DATABASE_URL_UNPOOLED=
DATABASE_URL_NON_POOLING=
DATABASE_URL_POOLING=
PGUSER=
PGHOST=
PGPASSWORD=
PGDATABASE=
PGPORT=

# OpenAI (required for letter generation)
OPENAI_API_KEY=sk-...

# Tavily (optional, for company research)
TAVILY_API_KEY=tvly-...

# Apollo (required for lead discovery)
APOLLO_API_KEY=
